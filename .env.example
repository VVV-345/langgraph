# ==================== 【大模型（LLM）接口配置】 ====================
# 服务的 API 地址（魔塔部署时设为你的 API 代理地址）
BASE_URL = "https://api.deepseek.com/v1/"

# 分析/规划/整合用的模型（推荐 deepseek-v3 或 qwen-max）
PROCESS_MODEL = "deepseek-v4-flash"

# 编码专用模型（可选，不设则复用 PROCESS_MODEL）
# CODING_MODEL = "deepseek-v4-flash"

# API Key（魔塔部署时在 Space 设置 → Environment Variables 中配置）
LLM_API_KEY = "sk-your-api-key-here"


# ==================== 【向量嵌入模型配置】 ====================
# 方式一：本地模型路径（需 pip install langchain-huggingface）
EMBEDDING_MODEL_PATH = "D:/AI2test/bge-m3"

# 向量维度（bge-m3 = 1024，bge-large-zh = 1024，text-embedding-3-small = 1536）
EMBEDDING_DIMENSION = 1024

# 方式二：API 模式（魔塔部署推荐，不需要本地模型文件）
# EMBEDDING_BASE_URL = "https://your-api.com/v1/"
# EMBEDDING_API_KEY = "your-key"
# EMBEDDING_MODEL_NAME = "text-embedding-3-small"

# Embedding 调用超时（秒）和最大重试次数
EMBEDDING_TIMEOUT = 30
EMBEDDING_MAX_RETRIES = 3

